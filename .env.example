# === AI Image Generation — Provider Abstraction Layer ===
# Set AI_PROVIDER to choose the primary backend:
#   openrouter | fal | replicate | openai | google
AI_PROVIDER=openrouter

# API Keys (sign up at each provider — only the active one needs to be set)
OPENROUTER_API_KEY=sk-or-...
FAL_API_KEY=
REPLICATE_API_TOKEN=r8_...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# === Model Selection ===
# Primary model for sketch variants (1-3)
AI_MODEL=black-forest-labs/flux-2-pro
# Alternative models for wildcard variants (4-5) — comma-separated
WILDCARD_MODELS=openai/gpt-image-1,google/imagen-4-ultra,google/nano-banana-pro

# === Generation Settings ===
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
GUIDANCE_SCALE=7.5
NUM_INFERENCE_STEPS=28
BATCH_SIZE=10
MAX_RETRIES=3
BATCH_PROCESSING_SIZE=500

# === Google Drive Sync ===
GOOGLE_CREDENTIALS_PATH=config/credentials.json
GDRIVE_OUTPUT_FOLDER_ID=1Vr184ZsX3k38xpmZkd8g2vwB5y9LYMRC

# === Quality Gate ===
MIN_QUALITY_SCORE=0.7
MAX_AI_ARTIFACT_SCORE=0.3
# Retry strategy: same_model_tweaked_prompt (Tim's decision)
QUALITY_RETRY_STRATEGY=same_model_tweaked_prompt

# === Local Paths ===
INPUT_COVERS_DIR=Input Covers
OUTPUT_COVERS_DIR=Output Covers
DATA_DIR=data
LOG_LEVEL=INFO

# === Webapp ===
PORT=8000
WORKERS=1
# No auth required (Tim's decision — private Railway URL)
WEBAPP_AUTH_ENABLED=false

# === Cost Controls ===
MAX_COST_USD=200.00
COST_PER_IMAGE_USD=0.055
